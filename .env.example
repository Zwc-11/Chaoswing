# ChaosWing local environment
# Copy this file to `.env`. The repository root `.env` is auto-loaded at startup.
# Do not commit real secrets — .env is in .gitignore.

# -----------------------------------------------------------------------------
# Django core
# -----------------------------------------------------------------------------
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=
DJANGO_STATIC_URL=/static/
DJANGO_STATIC_ROOT=staticfiles
DJANGO_SQLITE_PATH=db.sqlite3

# Production-facing hardening toggles. Leave these off for local development.
DJANGO_SECURE_SSL_REDIRECT=0
DJANGO_SESSION_COOKIE_SECURE=0
DJANGO_CSRF_COOKIE_SECURE=0
DJANGO_TRUST_X_FORWARDED_PROTO=0

# -----------------------------------------------------------------------------
# ChaosWing backend runtime
# -----------------------------------------------------------------------------
CHAOSWING_ENABLE_REMOTE_FETCH=1
CHAOSWING_ENABLE_LLM=0
CHAOSWING_HTTP_TIMEOUT_SECONDS=8
CHAOSWING_LOG_LEVEL=INFO

# Security & rate limiting (enabled by default in production, auto-skipped in DEBUG)
CHAOSWING_RATE_LIMIT_ENABLED=1
CHAOSWING_MAX_REQUEST_BODY_BYTES=1048576
CHAOSWING_TRENDING_CACHE_TTL=300

# -----------------------------------------------------------------------------
# Anthropic — set CHAOSWING_ENABLE_LLM=1 and add your key to activate
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
